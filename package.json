{
  "name": "jasonduffett-net",
  "description": "Monorepo for jasonduffett.net — infrastructure (CDK) and blog site.",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "test:update": "nx run-many -t test -- -u",
    "build": "nx run-many -t build",
    "clean": "nx run-many -t clean",
    "cdk:synth": "nx run @jasonduffett-net/cdk:synth",
    "cdk:diff": "nx run @jasonduffett-net/cdk:diff",
    "cdk:deploy": "nx run @jasonduffett-net/cdk:deploy",
    "cdk:deploy:stack": "nx run @jasonduffett-net/cdk:deploy:stack",
    "indexnow:ping": "nx run @jasonduffett-net/cdk:indexnow:ping",
    "site:smoke": "nx run @jasonduffett-net/cdk:smoke",
    "site:check-redirects": "nx run @jasonduffett-net/cdk:check:redirects",
    "site:build": "nx run @jasonduffett-net/site:build",
    "site:start": "nx run @jasonduffett-net/site:start",
    "site:clean": "nx run @jasonduffett-net/site:clean",
    "verify": "npm run format:check && npm run build && npm run lint && npm run test",
    "prepare": "husky"
  },
  "author": "Jason Duffett",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.2",
    "@nx/js": "22.7.5",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "nx": "22.7.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
