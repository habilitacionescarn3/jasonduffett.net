{
  "name": "@jasonduffett-net/site",
  "version": "1.0.0",
  "private": true,
  "description": "Blog and landing site for jasonduffett.net (Eleventy).",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "eleventy",
    "start": "eleventy --serve --quiet"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": [
          "default",
          "^default",
          {
            "env": "GA_MEASUREMENT_ID"
          },
          {
            "env": "GITHUB_SHA"
          }
        ]
      },
      "start": {
        "cache": false
      }
    }
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "satori": "^0.26.0"
  }
}
