# Google Analytics 4 measurement ID. When set at build time the GA4 tag and
# cookie consent banner are emitted into the layout. Leave unset for local dev
# or to disable analytics entirely.
GA_MEASUREMENT_ID=

# IndexNow domain-ownership key. Used by packages/cdk/scripts/indexnow-ping.mjs
# to notify Bing/Yandex/etc. of sitemap updates after deploy. Must match the
# filename of packages/site/static/<key>.txt — both are public.
INDEXNOW_KEY=
