{% set groups = posts | byYear %}
{% for group in groups %}
  <div class="year">{{ group.year }}</div>
  <ul class="posts">
    {% for post in group.posts %}
    {% set cat = post.data.tags | category %}
    <li{% if cat %} data-category="{{ cat }}"{% endif %}>
      {% include "partials/ornaments/sparkle.njk" %}
      <span class="post-meta">
        <time datetime="{{ post.date | htmlDateString }}">{{ post.date | shortDate }}</time><span class="reading-time">{{ post.templateContent | readingTime }}m</span>
      </span>
      <a class="title" href="{{ post.url | rel }}">{{ post.data.title }}</a>
      {% if cat %}<span class="tag {{ cat }}">{{ cat }}</span>{% endif %}
    </li>
    {% endfor %}
  </ul>
{% endfor %}

{% if not posts or posts.length == 0 %}
<p class="intro"><em>Nothing here yet.</em></p>
{% endif %}
