---
layout: layouts/base.njk
---
<article>
  <h1>{{ title }}</h1>
  <div class="meta">
    <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
    {% set cat = tags | category %}
    {% if cat %}<span class="tag {{ cat }}">{{ cat | capitalize }}</span>{% endif %}
  </div>

  {{ content | safe }}
</article>
