{% set pageCat = tags | category %}
{% if not pageCat and page.url and page.url.startsWith %}
  {% for cat in categories %}
    {% if page.url.startsWith("/" + cat + "/") %}{% set pageCat = cat %}{% endif %}
  {% endfor %}
{% endif %}<!doctype html>
<html lang="{{ site.language }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }} — {{ site.tagline }}{% endif %}</title>
  <meta name="description" content="{{ summary or site.description }}" />
  <meta name="theme-color" content="#0f0d0c" />
  <link rel="stylesheet" href="{{ '/assets/styles.css' | rel }}" />
  <link rel="alternate" type="application/rss+xml" href="{{ '/feed.xml' | rel }}" title="{{ site.title }}" />
  <meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}" />
  <meta property="og:description" content="{{ summary or site.description }}" />
  <meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
</head>
<body{% if pageCat %} data-category="{{ pageCat }}"{% endif %}>
  {% include "partials/ornaments/defs.njk" %}
  <div class="noise" aria-hidden="true"></div>
  <div class="wrap">

    <header class="site">
      <a class="brand" href="{{ '/' | rel }}">
        <span class="brand-name">jason duffett</span><span class="brand-dot">.</span>
      </a>
      <nav>
        {% for cat in categories %}
        <a class="nav-cat nav-{{ cat }}" href="{{ ('/' + cat + '/') | rel }}" {% if pageCat == cat %}aria-current="page"{% endif %}>{{ cat }}</a>
        {% endfor %}
        <a class="nav-about" href="{{ '/about/' | rel }}" {% if page.url == "/about/" %}aria-current="page"{% endif %}>about</a>
      </nav>
    </header>

    {{ content | safe }}

    <footer class="site">
      <span class="footer-sign">— jd</span>
      <span class="footer-squiggle">{% include "partials/ornaments/squiggle.njk" %}</span>
      <span class="footer-meta">
        &copy; {{ currentYear }} {{ site.author.name }}
        · <a href="{{ '/feed.xml' | rel }}">rss</a>
        · <a href="{{ '/about/' | rel }}">about</a>
      </span>
    </footer>

  </div>
</body>
</html>
