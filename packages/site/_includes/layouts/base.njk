<!doctype html>
<html lang="{{ site.language }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }} — {{ site.tagline }}{% endif %}</title>
  <meta name="description" content="{{ summary or site.description }}" />
  <link rel="stylesheet" href="{{ '/assets/styles.css' | rel }}" />
  <link rel="alternate" type="application/rss+xml" href="{{ '/feed.xml' | rel }}" title="{{ site.title }}" />
  <meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}" />
  <meta property="og:description" content="{{ summary or site.description }}" />
  <meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
</head>
<body>
  <div class="wrap">

    <header class="site">
      <a class="brand" href="{{ '/' | rel }}">{{ site.title }} <em>— {{ site.tagline }}</em></a>
      <nav>
        <a href="{{ '/' | rel }}" {% if page.url == "/" %}class="active"{% endif %}>Writing</a>
        {% for cat in categories %}
        <a href="{{ ('/' + cat + '/') | rel }}" {% if page.url.startsWith and page.url.startsWith('/' + cat) %}class="active"{% endif %}>{{ cat | capitalize }}</a>
        {% endfor %}
        <a href="{{ '/about/' | rel }}" {% if page.url == "/about/" %}class="active"{% endif %}>About</a>
      </nav>
    </header>

    {{ content | safe }}

    <footer class="site">
      <span>&copy; {{ currentYear }} {{ site.author.name }}</span>
      <span><a href="{{ '/feed.xml' | rel }}">RSS</a> · <a href="{{ '/about/' | rel }}">About</a></span>
    </footer>

  </div>
</body>
</html>
