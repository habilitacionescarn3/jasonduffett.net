{% set pageCat = tags | category %}
{% if not pageCat and page.url and page.url.startsWith %}
  {% for cat in categories %}
    {% if page.url.startsWith("/" + cat + "/") %}{% set pageCat = cat %}{% endif %}
  {% endfor %}
{% endif %}
{% set showLicense = site.defaultLicense and not noLicense %}<!doctype html>
<html lang="{{ site.language }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }} — {{ site.tagline }}{% endif %}</title>
  <meta name="description" content="{{ summary or site.description }}" />
  <meta http-equiv="content-language" content="{{ site.language }}" />
  <meta name="author" content="{{ site.author.name }}" />
  <meta name="theme-color" content="#0f0d0c" />
  <meta name="build-sha" content="{{ build.sha }}" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  {% if showLicense %}
  <link rel="license" href="{{ site.defaultLicense }}" />
  <meta name="copyright" content="© {{ currentYear }} {{ site.author.name }}, {{ site.licenseName }}" />
  <meta name="tdm-reservation" content="0" />
  <meta name="tdm-policy" content="{{ site.url }}{{ site.licensePolicyUrl }}" />
  {% endif %}
  <link rel="icon" href="{{ '/favicon.ico' | rel }}" sizes="32x32" />
  <link rel="icon" href="{{ '/favicon.svg' | rel }}" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="{{ '/apple-touch-icon.png' | rel }}" />
  <link rel="manifest" href="{{ '/site.webmanifest' | rel }}" />
  <link rel="stylesheet" href="{{ '/assets/styles.css' | rel }}" />
  <link rel="alternate" type="application/rss+xml" href="{{ '/feed.xml' | rel }}" title="{{ site.title }}" />
  {% set ogImageUrl = site.url + ('/og/' + page.fileSlug + '.png' if layout == 'layouts/post.njk' else site.defaultOgImage) %}
  <meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}" />
  <meta property="og:description" content="{{ summary or site.description }}" />
  <meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:site_name" content="{{ site.title }}" />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:image" content="{{ ogImageUrl }}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}" />
  <meta name="twitter:description" content="{{ summary or site.description }}" />
  <meta name="twitter:image" content="{{ ogImageUrl }}" />
  {% if layout == 'layouts/post.njk' %}
  <meta property="article:published_time" content="{{ page.date | htmlDateString }}" />
  <meta property="article:author" content="{{ site.author.name }}" />
  {% include "partials/jsonld-post.njk" %}
  {% else %}
  {% include "partials/jsonld-site.njk" %}
  {% endif %}
  {% include "partials/analytics.njk" %}
</head>
<body{% if pageCat %} data-category="{{ pageCat }}"{% endif %}>
  {% include "partials/ornaments/defs.njk" %}
  <div class="noise" aria-hidden="true"></div>
  <div class="wrap">

    <header class="site">
      <a class="brand" href="{{ '/' | rel }}">
        <span class="brand-name">jason duffett</span><span class="brand-dot">.</span>
      </a>
      <nav>
        {% for cat in categories %}
        <a class="nav-cat nav-{{ cat }}" href="{{ ('/' + cat + '/') | rel }}" {% if pageCat == cat %}aria-current="page"{% endif %}>{{ cat }}</a>
        {% endfor %}
        <a class="nav-about" href="{{ '/about/' | rel }}" {% if page.url == "/about/" %}aria-current="page"{% endif %}>about</a>
      </nav>
    </header>

    {{ content | safe }}

    <footer class="site">
      <span class="footer-sign">— jd</span>
      <span class="footer-squiggle">{% include "partials/ornaments/squiggle.njk" %}</span>
      <span class="footer-meta">
        &copy; {{ currentYear }} {{ site.author.name }}{% if showLicense %} · <a rel="license" href="{{ site.defaultLicense }}">{{ site.licenseName }}</a>{% endif %}
        · <a href="{{ '/feed.xml' | rel }}">rss</a>
        · <a href="{{ '/about/' | rel }}">about</a>
        {% if analytics.measurementId %}· <a href="#" data-consent-reopen>cookies</a>{% endif %}
      </span>
    </footer>

  </div>
  {% include "partials/consent-banner.njk" %}
</body>
</html>
