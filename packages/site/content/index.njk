---
layout: layouts/base.njk
title: ""
eleventyExcludeFromCollections: true
---
<section class="hero">
  <div class="hero-text">
    <h1 class="hero-headline">
      <span class="line">these</span>
      <span class="line"><span class="accent-1">things</span></span>
      <span class="line">i <span class="accent-2">do.</span></span>
    </h1>
    <span class="hero-squiggle">{% include "partials/ornaments/squiggle.njk" %}</span>
    <p class="hero-tagline">by day, <em>software engineering</em>; by night, <strong>ukulele</strong>. these are the notes that didn&rsquo;t fit on a hard drive.</p>
  </div>
  <figure class="hero-sketch">
    <img src="{{ '/assets/sketch-profile.jpeg' | rel }}" alt="Hand-drawn self-portrait of Jason &mdash; wild hair, stubble, skull t-shirt, blue jeans." />
  </figure>
</section>

{% set latest = collections.posts | last %}
{% if latest %}
{% set latestCat = latest.data.tags | category %}
{% set latestImg = latest.data.ogImage %}
<a class="currently{% if not latestImg %} no-img{% endif %}" href="{{ latest.url | rel }}"{% if latestCat %} data-category="{{ latestCat }}"{% endif %}{% if latestImg %} style="background-image: url('{{ latestImg | rel }}')"{% endif %}>
  <span class="currently-eyebrow">{% include "partials/ornaments/sparkle.njk" %} currently</span>
  <span class="currently-title">{{ latest.data.title }}</span>
  {% if latest.data.summary %}<span class="currently-summary">{{ latest.data.summary }}</span>{% endif %}
  <span class="currently-meta">
    <time datetime="{{ latest.date | htmlDateString }}">{{ latest.date | readableDate }}</time>
    <span class="sep" aria-hidden="true">&middot;</span>
    <span>{{ latest.templateContent | readingTime }} min read</span>
    {% if latestCat %}<span class="sep" aria-hidden="true">&middot;</span><span class="tag {{ latestCat }}">{{ latestCat }}</span>{% endif %}
  </span>
</a>
{% endif %}

<div class="section-heading">
  {% include "partials/ornaments/sparkle.njk" %}
  <span>recent things</span>
</div>

{% set posts = collections.posts %}
{% include "partials/post-list.njk" %}

{% include "partials/threads.njk" %}
