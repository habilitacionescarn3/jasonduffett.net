{
  "Description": "CloudWatch alarms for site metrics that AWS only emits in us-east-1.",
  "Parameters": {
    "BootstrapVersion": {
      "Default": "/cdk-bootstrap/hnb659fds/version",
      "Description": "Version of the CDK Bootstrap resources in this environment, automatically retrieved from SSM Parameter Store. [cdk:skip]",
      "Type": "AWS::SSM::Parameter::Value<String>",
    },
  },
  "Resources": {
    "CustomCrossRegionExportReaderCustomResourceProviderHandler46647B68": {
      "DependsOn": [
        "CustomCrossRegionExportReaderCustomResourceProviderRole10531BBD",
      ],
      "Properties": {
        "Code": {
          "S3Bucket": "cdk-hnb659fds-assets-111111111111-us-east-1",
          "S3Key": "<asset-hash>.zip",
        },
        "Handler": "__entrypoint__.handler",
        "MemorySize": 128,
        "Role": {
          "Fn::GetAtt": [
            "CustomCrossRegionExportReaderCustomResourceProviderRole10531BBD",
            "Arn",
          ],
        },
        "Runtime": "nodejs24.x",
        "Timeout": 900,
      },
      "Type": "AWS::Lambda::Function",
    },
    "CustomCrossRegionExportReaderCustomResourceProviderRole10531BBD": {
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com",
              },
            },
          ],
          "Version": "2012-10-17",
        },
        "ManagedPolicyArns": [
          {
            "Fn::Sub": "arn:${AWS::Partition}:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole",
          },
        ],
        "Policies": [
          {
            "PolicyDocument": {
              "Statement": [
                {
                  "Action": [
                    "ssm:AddTagsToResource",
                    "ssm:RemoveTagsFromResource",
                    "ssm:GetParameters",
                  ],
                  "Effect": "Allow",
                  "Resource": {
                    "Fn::Join": [
                      "",
                      [
                        "arn:",
                        {
                          "Ref": "AWS::Partition",
                        },
                        ":ssm:us-east-1:111111111111:parameter/cdk/exports/JasonDuffettNetCdnAlarmsStack/*",
                      ],
                    ],
                  },
                },
              ],
              "Version": "2012-10-17",
            },
            "PolicyName": "Inline",
          },
        ],
      },
      "Type": "AWS::IAM::Role",
    },
    "ExportsReader8B249524": {
      "DeletionPolicy": "Delete",
      "Properties": {
        "ReaderProps": {
          "imports": {
            "/cdk/exports/JasonDuffettNetCdnAlarmsStack/JasonDuffettNetSiteStackeuwest2Refjasonduffettnetcdn02768B87E79DE679": "{{resolve:ssm:/cdk/exports/JasonDuffettNetCdnAlarmsStack/JasonDuffettNetSiteStackeuwest2Refjasonduffettnetcdn02768B87E79DE679}}",
            "/cdk/exports/JasonDuffettNetCdnAlarmsStack/JasonDuffettNetSiteStackeuwest2RefjasonduffettnethealthCheck0335EDCA5A7B6B0F": "{{resolve:ssm:/cdk/exports/JasonDuffettNetCdnAlarmsStack/JasonDuffettNetSiteStackeuwest2RefjasonduffettnethealthCheck0335EDCA5A7B6B0F}}",
          },
          "prefix": "JasonDuffettNetCdnAlarmsStack",
          "region": "us-east-1",
        },
        "ServiceToken": {
          "Fn::GetAtt": [
            "CustomCrossRegionExportReaderCustomResourceProviderHandler46647B68",
            "Arn",
          ],
        },
      },
      "Type": "Custom::CrossRegionExportReader",
      "UpdateReplacePolicy": "Delete",
    },
    "jasonduffettnetcdnAlarmsDefaultBehaviorViewerRequestExecutionErrorsAlarm8B0DBA51": {
      "Properties": {
        "AlarmActions": [
          {
            "Fn::ImportValue": "JasonDuffettNetUsEast1AlertsStack:ExportsOutputRefjasonduffettnetusEast1AlertsED7A8D43F3302E6E",
          },
        ],
        "AlarmDescription": "CloudFront Function on default behavior (viewer-request) is raising execution errors. Threshold: > 0 errors in 1 minute.",
        "AlarmName": "jason-duffett-net-cdn-alarms-stack/jasonduffett-net/cdn-alarms/default-behavior-viewer-request-execution-errors",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 1,
        "Dimensions": [
          {
            "Name": "FunctionName",
            "Value": "JasonDuffettNetSiteStack-redirect",
          },
          {
            "Name": "Region",
            "Value": "Global",
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "FunctionExecutionErrors",
        "Namespace": "AWS/CloudFront",
        "Period": 60,
        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "jasonduffettnetcdnAlarmsDefaultBehaviorViewerRequestThrottlesAlarmE4B33F8B": {
      "Properties": {
        "AlarmActions": [
          {
            "Fn::ImportValue": "JasonDuffettNetUsEast1AlertsStack:ExportsOutputRefjasonduffettnetusEast1AlertsED7A8D43F3302E6E",
          },
        ],
        "AlarmDescription": "CloudFront Function on default behavior (viewer-request) is being throttled — likely exceeding its 1ms compute budget. Threshold: > 0 throttles in 1 minute.",
        "AlarmName": "jason-duffett-net-cdn-alarms-stack/jasonduffett-net/cdn-alarms/default-behavior-viewer-request-throttles",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 1,
        "Dimensions": [
          {
            "Name": "FunctionName",
            "Value": "JasonDuffettNetSiteStack-redirect",
          },
          {
            "Name": "Region",
            "Value": "Global",
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "FunctionThrottles",
        "Namespace": "AWS/CloudFront",
        "Period": 60,
        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "jasonduffettnetcdnAlarmsDefaultBehaviorViewerRequestValidationErrorsAlarm8655832F": {
      "Properties": {
        "AlarmActions": [
          {
            "Fn::ImportValue": "JasonDuffettNetUsEast1AlertsStack:ExportsOutputRefjasonduffettnetusEast1AlertsED7A8D43F3302E6E",
          },
        ],
        "AlarmDescription": "CloudFront Function on default behavior (viewer-request) is producing validation errors. Threshold: > 0 errors in 1 minute.",
        "AlarmName": "jason-duffett-net-cdn-alarms-stack/jasonduffett-net/cdn-alarms/default-behavior-viewer-request-validation-errors",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 1,
        "Dimensions": [
          {
            "Name": "FunctionName",
            "Value": "JasonDuffettNetSiteStack-redirect",
          },
          {
            "Name": "Region",
            "Value": "Global",
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "FunctionValidationErrors",
        "Namespace": "AWS/CloudFront",
        "Period": 60,
        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "jasonduffettnetcdnAlarmsErrorRateAlarm69D6C98E": {
      "Properties": {
        "AlarmActions": [
          {
            "Fn::ImportValue": "JasonDuffettNetUsEast1AlertsStack:ExportsOutputRefjasonduffettnetusEast1AlertsED7A8D43F3302E6E",
          },
        ],
        "AlarmDescription": "CloudFront distribution 5xx error rate is elevated. Threshold: > 5% in 1 minute.",
        "AlarmName": "jason-duffett-net-cdn-alarms-stack/jasonduffett-net/cdn-alarms/error-rate",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 5,
        "Dimensions": [
          {
            "Name": "DistributionId",
            "Value": {
              "Fn::GetAtt": [
                "ExportsReader8B249524",
                "/cdk/exports/JasonDuffettNetCdnAlarmsStack/JasonDuffettNetSiteStackeuwest2Refjasonduffettnetcdn02768B87E79DE679",
              ],
            },
          },
          {
            "Name": "Region",
            "Value": "Global",
          },
        ],
        "EvaluationPeriods": 5,
        "MetricName": "5xxErrorRate",
        "Namespace": "AWS/CloudFront",
        "Period": 60,
        "Statistic": "Average",
        "Threshold": 5,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "jasonduffettnetcdnAlarmsOriginLatencyAlarm49242F7D": {
      "Properties": {
        "AlarmActions": [
          {
            "Fn::ImportValue": "JasonDuffettNetUsEast1AlertsStack:ExportsOutputRefjasonduffettnetusEast1AlertsED7A8D43F3302E6E",
          },
        ],
        "AlarmDescription": "CloudFront origin latency is elevated. Threshold: > 5000ms p90 in 1 minute.",
        "AlarmName": "jason-duffett-net-cdn-alarms-stack/jasonduffett-net/cdn-alarms/origin-latency",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 5,
        "Dimensions": [
          {
            "Name": "DistributionId",
            "Value": {
              "Fn::GetAtt": [
                "ExportsReader8B249524",
                "/cdk/exports/JasonDuffettNetCdnAlarmsStack/JasonDuffettNetSiteStackeuwest2Refjasonduffettnetcdn02768B87E79DE679",
              ],
            },
          },
          {
            "Name": "Region",
            "Value": "Global",
          },
        ],
        "EvaluationPeriods": 5,
        "ExtendedStatistic": "p90",
        "MetricName": "OriginLatency",
        "Namespace": "AWS/CloudFront",
        "Period": 60,
        "Threshold": 5000,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "jasonduffettnethealthCheckAlarmsHealthCheckStatusAlarmAF2BFD73": {
      "Properties": {
        "AlarmActions": [
          {
            "Fn::ImportValue": "JasonDuffettNetUsEast1AlertsStack:ExportsOutputRefjasonduffettnetusEast1AlertsED7A8D43F3302E6E",
          },
        ],
        "AlarmDescription": "Route 53 health check is reporting unhealthy. Threshold: HealthCheckStatus < 1 (Minimum, 1 minute).",
        "AlarmName": "jason-duffett-net-cdn-alarms-stack/jasonduffett-net/health-check-alarms/health-check-status",
        "ComparisonOperator": "LessThanThreshold",
        "DatapointsToAlarm": 1,
        "Dimensions": [
          {
            "Name": "HealthCheckId",
            "Value": {
              "Fn::GetAtt": [
                "ExportsReader8B249524",
                "/cdk/exports/JasonDuffettNetCdnAlarmsStack/JasonDuffettNetSiteStackeuwest2RefjasonduffettnethealthCheck0335EDCA5A7B6B0F",
              ],
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "HealthCheckStatus",
        "Namespace": "AWS/Route53",
        "Period": 60,
        "Statistic": "Minimum",
        "Threshold": 1,
        "TreatMissingData": "breaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
  },
  "Rules": {
    "CheckBootstrapVersion": {
      "Assertions": [
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Contains": [
                  [
                    "1",
                    "2",
                    "3",
                    "4",
                    "5",
                  ],
                  {
                    "Ref": "BootstrapVersion",
                  },
                ],
              },
            ],
          },
          "AssertDescription": "CDK bootstrap stack version 6 required. Please run 'cdk bootstrap' with a recent version of the CDK CLI.",
        },
      ],
    },
  },
}