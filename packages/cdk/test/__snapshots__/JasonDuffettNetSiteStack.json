e-esxi/\",\n  \"/post/5390685611/editing-etchosts-in-mac-os-x\": \"/tech/editing-etchosts-in-mac-os-x/\",\n  \"/post/5416982514/iscsi-vmware-recommended-reading\": \"/tech/iscsi-vmware-recommended-reading/\",\n  \"/post/5448151233/administering-cross-forest-domains-with-a-single-login\": \"/tech/administering-cross-forest-domains-with-a-single-login/\",\n  \"/post/5602579085/tumblr-tag-clouds\": \"/misc/tumblr-tag-clouds/\",\n  \"/post/5633415993/microsoft-key-management-service\": \"/tech/microsoft-key-management-service/\",\n  \"/post/5663131672/machine-specifications-utility-naming\": \"/tech/machine-specifications-utility-naming/\",\n  \"/post/5663782953/guide-to-object-equality-part-4\": \"/tech/guide-to-object-equality-part-4/\",\n  \"/post/5766799224/resharper-stylecop-and-mspec-playing-nice\": \"/tech/resharper-stylecop-and-mspec-playing-nice/\",\n  \"/post/5828257268/more-resharper-and-mspec-playing-nice\": \"/tech/more-resharper-and-mspec-playing-nice/\",\n  \"/post/6137285032/esxi-active-directory-domain-trust\": \"/tech/esxi-active-directory-domain-trust/\",\n  \"/post/6385048950/gmail-custom-domain-name-on-behalf-of\": \"/tech/gmail-custom-domain-name-on-behalf-of/\",\n  \"/post/69833281829/idonethis-alfredapp-daily-standup-nirvana\": \"/tech/idonethis-alfredapp-daily-standup-nirvana/\",\n  \"/post/82802432966/recording-deployments-in-new-relic-with-powershells\": \"/tech/recording-deployments-in-new-relic-with-powershells/\"\n};\n\nfunction handler(event) {\n  var req = event.request;\n  var host = req.headers.host && req.headers.host.value;\n  var uri = req.uri;\n\n  if (host === \"www.jasonduffett.net\") {\n    return {\n      statusCode: 301,\n      statusDescription: \"Moved Permanently\",\n      headers: {\n        location: { value: \"https://jasonduffett.net\" + uri }\n      }\n    };\n  }\n\n  if (REDIRECTS[uri]) {\n    return {\n      statusCode: 301,\n      statusDescription: \"Moved Permanently\",\n      headers: {\n        location: { value